# Azure OpenAI Configuration
AZURE_OPENAI_KEY=your_azure_openai_api_key
AZURE_OPENAI_ENDPOINT=https://your-instance.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Azure Cognitive Search Configuration
AZURE_SEARCH_ENDPOINT=https://your-search-instance.search.windows.net/
AZURE_SEARCH_KEY=your_search_api_key
AZURE_SEARCH_INDEX_NAME=customer-support-docs

# Application Configuration
APP_ENV=development
APP_NAME=customer-support-ai-agent
APP_VERSION=1.0.0
DEBUG=True

# Agent Configuration
AGENT_MODEL=gpt-4
AGENT_TEMPERATURE=0.7
AGENT_MAX_TOKENS=2048
AGENT_TOP_K_RETRIEVAL=5

# RAG Configuration
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
RAG_MIN_SIMILARITY_SCORE=0.5

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=True

# Evaluation Configuration
EVAL_THRESHOLD_FAITHFULNESS=0.85
EVAL_THRESHOLD_CONTEXT_PRECISION=0.80
EVAL_THRESHOLD_ANSWER_RELEVANCE=0.75

# Monitoring & Observability
JAEGER_ENABLED=False
JAEGER_AGENT_HOST=localhost
JAEGER_AGENT_PORT=6831
PROMETHEUS_ENABLED=True

# Database (if using persistence)
DATABASE_URL=sqlite:///./chat_history.db

# Security
SECRET_KEY=your_secret_key_here
ALLOWED_ORIGINS=["http://localhost:3000", "https://yourdomain.com"]

# Rate Limiting
RATE_LIMIT_CALLS=100
RATE_LIMIT_PERIOD=60

# Timeout Configuration
REQUEST_TIMEOUT_SECONDS=30
LLM_TIMEOUT_SECONDS=60
SEARCH_TIMEOUT_SECONDS=10
